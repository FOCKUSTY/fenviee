{
	"compilerOptions": {
		"target": "es2024",
		"module": "CommonJS",
		"rootDir": "./src",
		"outDir": "./dist",
    "sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["./**/*.ts"],
	"exclude": ["node_modules", "dist"]
}